# ─────────────────────────────────────────────────────────────
# Flask Configuration
# ─────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# ─────────────────────────────────────────────────────────────
# Database (path relatif untuk dev, /data/... untuk Render)
# ─────────────────────────────────────────────────────────────
DATABASE_PATH=data/tpxo_seribu.db
LUWES_DB_PATH=data/luwes_raw.db

# ─────────────────────────────────────────────────────────────
# CORS — pisahkan dengan koma tanpa spasi
# ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────────────────────
# TPXO Source Data (hanya dibutuhkan saat preprocessing)
# ─────────────────────────────────────────────────────────────
TPXO_FILE=data/TPXO9_atlas_v5.nc
